ph","position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"children":[{"type":"text","value":"Lo que está ausente es igualmente revelador. No hay nada sobre cómo reconocer las necesidades sensoriales de un estudiante autista en el aula, cómo comunicarse eficazmente con sus familias, qué implica la neurodiversidad en términos de variabilidad real entre personas, ni estrategias concretas de acompañamiento emocional.","position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"key":"PmhfZZpGqQ"}],"key":"UZ0WzOM9Yx"},{"type":"paragraph","position":{"start":{"line":57,"column":1},"end":{"line":57,"column":1}},"children":[{"type":"text","value":"La propia Circular N°586 declara que su propósito es un “cambio de paradigma que debe involucrar a toda la comunidad educativa”. La capacitación que la Superintendencia dio a sus propios funcionarios no refleja ese espíritu: es un resumen jurídico, no una formación transformadora.","position":{"start":{"line":57,"column":1},"end":{"line":57,"column":1}},"key":"VgYLKNMHhA"}],"key":"XiGg1DPKD3"},{"type":"paragraph","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"children":[{"type":"text","value":"Un dato transversal a todas las instancias: ","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"key":"BKiDFgFtpb"},{"type":"strong","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"children":[{"type":"text","value":"ninguna de las capacitaciones internas contempló mecanismo de evaluación ni aprobación exigible a los participantes.","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"key":"gpCnL1SkKI"}],"key":"LQ0jkiyUP5"}],"key":"zAvrsrkBNJ"},{"type":"heading","depth":4,"position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"children":[{"type":"text","value":"2. Curso CINTEC, 16 horas (noviembre–diciembre 2024)","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"key":"tZbm8LBfcb"}],"identifier":"id-2-curso-cintec-16-horas-noviembre-diciembre-2024","label":"2. Curso CINTEC, 16 horas (noviembre–diciembre 2024)","html_id":"id-2-curso-cintec-16-horas-noviembre-diciembre-2024","implicit":true,"key":"vzbUJ3ZnJM"},{"type":"paragraph","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"children":[{"type":"text","value":"El único curso con mayor extensión fue ejecutado por la Fundación CINTEC, en modalidad virtual sincrónica, con un costo de $2.000.000. Contempló evaluación por asistencia y prueba escrita.","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"key":"LrpVelrAHF"}],"key":"MeLN8eF9dh"},{"type":"paragraph","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"children":[{"type":"text","value":"Sin embargo, solo 27 funcionarios fueron capacitados. ","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"g8kFI3hgh8"},{"type":"strong","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"children":[{"type":"text","value":"821 quedaron sin este curso — más del 96% del personal del servicio.","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"VZ6jMEYvo7"}],"key":"fIUVWryPnv"},{"type":"text","value":" Incluso en 8 regiones no se incluyó a ninguno de sus funcionarios en esta instancia.","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"iP8nuLGgqA"}],"key":"S3u4CSWgby"},{"type":"thematicBreak","position":{"start":{"line":67,"column":1},"end":{"line":67,"column":1}},"key":"W1ApGVxenc"},{"type":"heading","depth":3,"position":{"start":{"line":69,"column":1},"end":{"line":69,"column":1}},"children":[{"type":"text","value":"La paradoja que no puedo ignorar","position":{"start":{"line":69,"column":1},"end":{"line":69,"column":1}},"key":"dWpMjXk3C7"}],"identifier":"la-paradoja-que-no-puedo-ignorar","label":"La paradoja que no puedo ignorar","html_id":"la-paradoja-que-no-puedo-ignorar","implicit":true,"key":"kNh86pxHec"},{"type":"paragraph","position":{"start":{"line":71,"column":1},"end":{"line":71,"column":1}},"children":[{"type":"text","value":"La Superintendencia de Educación exige a los establecimientos que todos los años capacitemos sobre autismo al 100% de nuestros funcionarios, informemos en detalle quiénes fueron los relatores y presentemos el material usado. Sin embargo, sus propios fiscalizadores —las personas que van a los colegios a verificar el cumplimiento de la Ley de Autismo— recibieron, en el mejor de los casos, hora y media de formación, sin evaluación y sin certificación.","position":{"start":{"line":71,"column":1},"end":{"line":71,"column":1}},"key":"e2BhCD5K7a"}],"key":"KeDzBuoSTx"},{"type":"paragraph","position":{"start":{"line":73,"column":1},"end":{"line":73,"column":1}},"children":[{"type":"text","value":"Esto no es un juicio a quienes trabajan en la Superintendencia. Es una pregunta sobre la coherencia entre lo que se exige afuera y lo que se practica adentro.","position":{"start":{"line":73,"column":1},"end":{"line":73,"column":1}},"key":"XNrxcwwrYI"}],"key":"eCD3xEBmA8"},{"type":"thematicBreak","position":{"start":{"line":75,"column":1},"end":{"line":75,"column":1}},"key":"p81XQcLk2t"},{"type":"heading","depth":3,"position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"children":[{"type":"text","value":"¿Qué podría cambiar?","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"KKRe2QZv7N"}],"identifier":"id-qu-podr-a-cambiar","label":"¿Qué podría cambiar?","html_id":"id-qu-podr-a-cambiar","implicit":true,"key":"SowslezvyV"},{"type":"paragraph","position":{"start":{"line":79,"column":1},"end":{"line":79,"column":1}},"children":[{"type":"text","value":"Dos medidas merecen discutirse:","position":{"start":{"line":79,"column":1},"end":{"line":79,"column":1}},"key":"Sfutk4pvKS"}],"key":"eRSK06T1cM"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":81,"column":1},"end":{"line":83,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"children":[{"type":"text","value":"Evaluación periódica","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"P45bXF5UE9"}],"key":"FodanT3JGt"},{"type":"text","value":" —al menos anual— de los funcionarios en las normativas que fiscalizan, incluida la Ley de Autismo. No como mecanismo punitivo, sino como garantía de un piso común de conocimiento.","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"adHOSfenu0"}],"key":"kntjCq6kxM"}],"key":"LMmORdUFW1"},{"type":"listItem","spread":true,"position":{"start":{"line":82,"column":1},"end":{"line":83,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"children":[{"type":"text","value":"Prueba de conocimientos normativos","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"key":"MJwH570IXW"}],"key":"EN7Hlbj3up"},{"type":"text","value":" en los procesos de selección de fiscalizadores, similar a lo que ya aplica el Ministerio Público.","position":{"start":{"line":82,"column":1},"end":{"line":82,"column":1}},"key":"cglPaclsts"}],"key":"WM9CzBmVVY"}],"key":"EKgMOowrSL"}],"key":"UEiZxtFRCz"},{"type":"paragraph","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"children":[{"type":"text","value":"Ninguna de estas medidas requiere recursos extraordinarios. Requieren decisión institucional.","position":{"start":{"line":84,"column":1},"end":{"line":84,"column":1}},"key":"T6EZJLpWu3"}],"key":"j1reCtEbik"},{"type":"thematicBreak","position":{"start":{"line":86,"column":1},"end":{"line":86,"column":1}},"key":"MOBT03X35i"},{"type":"paragraph","pos